#!/bin/bash

set -euo pipefail

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if [[ -z "$staged_files" ]]; then
  exit 0
fi

echo "🧪 Running canonical pre-commit checks..."

legacy_specify_writes="$(echo "$staged_files" | grep -E '^\.specify/' || true)"
legacy_specify_disallowed="$(echo "$legacy_specify_writes" | grep -Ev '^\.specify/README\.md$' || true)"
if [[ -n "$legacy_specify_disallowed" ]]; then
  echo ""
  echo "❌ Commit blocked: staged writes into frozen legacy .specify detected."
  echo "$legacy_specify_disallowed" | sed 's/^/  - /'
  echo ""
  echo "Move operational updates to openspec/ or workflow/ instead."
  exit 1
fi

task_file_changes="$(echo "$staged_files" | grep -E '^openspec/changes/.*/tasks\.md$' || true)"
if [[ -n "$task_file_changes" ]] || echo "$staged_files" | grep -q '^workflow/state/task-registry\.md$'; then
  if [[ -x "workflow/scripts/tasks-sync.sh" ]] && ! workflow/scripts/tasks-sync.sh --check >/dev/null 2>&1; then
    echo ""
    echo "❌ Commit blocked: workflow/state/task-registry.md is stale."
    echo "Run: workflow/scripts/tasks-sync.sh"
    exit 1
  fi
fi

if [[ -x "workflow/scripts/post-impl-check.sh" ]] && ! workflow/scripts/post-impl-check.sh --staged >/dev/null 2>&1; then
  echo ""
  echo "❌ Commit blocked: canonical post-implementation evidence is missing."
  echo "Stage updates in openspec/, workflow/state/, or docs/ before committing code."
  exit 1
fi

code_regex='\.(c|cc|cpp|cs|go|h|hpp|java|js|jsx|kt|mjs|php|py|rb|rs|scala|sh|sql|swift|ts|tsx)$'
todo_hits=""

while IFS= read -r file; do
  [[ -z "$file" ]] && continue

  if [[ "$file" =~ $code_regex ]]; then
    file_hits="$(git diff --cached --unified=0 -- "$file" | { grep -nE '^\+.*\b(TODO|FIXME|XXX)\b' || true; })"
    if [[ -n "$file_hits" ]]; then
      todo_hits="${todo_hits}\n${file}\n${file_hits}\n"
    fi
  fi
done <<< "$staged_files"

if [[ -n "$todo_hits" ]]; then
  echo ""
  echo "❌ Commit blocked: new inline TODO/FIXME/XXX comments detected."
  echo "Track follow-up in openspec/changes or workflow/state instead."
  printf "%b\n" "$todo_hits"
  exit 1
fi

# Check A: Spec-drift for active openspec changes
# Gracefully skipped in CI (gate runs there instead).
if [ -z "${CI:-}" ]; then
  active_change_ids=$(git diff --cached --name-only | grep -oE 'openspec/changes/[A-Za-z0-9][A-Za-z0-9._-]*' | sed 's|openspec/changes/||' | sort -u || true)
  for cid in $active_change_ids; do
    if [ -x "workflow/scripts/spec-drift-check.sh" ]; then
      if ! workflow/scripts/spec-drift-check.sh --change "$cid" --quiet; then
        echo ""
        echo "❌ Commit blocked: spec-drift detected for change $cid"
        echo "   Run:    workflow/scripts/spec-drift-check.sh --change $cid"
        echo "   Bypass: git commit --no-verify  (NOT recommended)"
        exit 1
      fi
    fi
  done
fi

# Check B: Claim-evidence in commit message (warn only)
if [ -f ".git/COMMIT_EDITMSG" ] && [ -x "workflow/scripts/claim-evidence-check.sh" ]; then
  if ! workflow/scripts/claim-evidence-check.sh .git/COMMIT_EDITMSG --quiet 2>&1; then
    echo ""
    echo "⚠️  WARNING: Commit message contains claims without evidence (test-name, file:line, exit code)"
    echo "   Continuing anyway -- review the message above."
    # NOT exit 1 -- only warn
  fi
fi

echo "✅ pre-commit checks passed"
exit 0
